# Backend secrets. Keep these on the server side only.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-live-2.5-flash-native-audio
GEMINI_API_VERSION=v1alpha
GIADA_SERVER_HOST=127.0.0.1
GIADA_SERVER_PORT=8787
GIADA_DATABASE_URL=file:./data/giada.sqlite

# Optional Discord addon.
DISCORD_BOT_TOKEN=
DISCORD_BEARER_TOKEN=
DISCORD_APPLICATION_ID=
DISCORD_PUBLIC_KEY=
DISCORD_GUILD_ID=
DISCORD_REGISTER_GLOBAL_COMMANDS=false
DISCORD_GEMINI_MODEL=gemini-2.5-flash

# Local policy defaults.
GIADA_DEFAULT_LANGUAGE=it-IT
GIADA_ALLOWED_ORIGINS=tauri://localhost,http://localhost:1420
