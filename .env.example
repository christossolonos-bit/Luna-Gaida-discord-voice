# Core service
GIADA_SERVER_HOST=127.0.0.1
GIADA_SERVER_PORT=8787
GIADA_PUBLIC_URL=http://127.0.0.1:8787
GIADA_POSTGRES_URL=postgresql://giada:change-me@127.0.0.1:5432/giada
# Generate with: openssl rand -base64 32
GIADA_MASTER_KEY=
GIADA_OWNER_DISCORD_USER_ID=

# Discord bot and dashboard OAuth application
DISCORD_BOT_TOKEN=
DISCORD_APPLICATION_ID=
DISCORD_CLIENT_SECRET=
DISCORD_PUBLIC_KEY=

# Stripe test/live credentials
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Provider models and endpoints. API keys are stored encrypted through the owner dashboard.
GEMINI_MODEL=gemini-live-2.5-flash-native-audio
GROQ_MODEL=llama-3.3-70b-versatile
NVIDIA_IMAGE_MODEL=moonshotai/kimi-k2.6

# Local Discord voice (faster-whisper STT + XTTS + Ollama). Set GIADA_VOICE_PROVIDER=local to enable.
GIADA_VOICE_PROVIDER=local
LOCAL_VOICE_PYTHON=python
LOCAL_VOICE_SCRIPT=./scripts/local_voice_service.py
WHISPER_MODEL=base
WHISPER_LANGUAGE=en
WHISPER_NO_SPEECH_THRESHOLD=0.35
XTTS_SPEAKER_WAV=./voices/Serafina - Sensual Temptress_pvc_sp92_s31_sb81_v3.mp3
XTTS_LANGUAGE=en
FFMPEG_BINARY=ffmpeg

# Luna voice behavior
LUNA_VOICE_INPUT_MODE=ptt
LUNA_WAKE_REQUIRED=false
LUNA_WAKE_PHRASES=hey luna,hello luna
LUNA_SPEECH_END_SILENCE_MS=5000
LUNA_ECHO_MUTE_MS=1200
LUNA_USER_VOICE_MEMORY=true
LUNA_LIFE_MEMORY=true
LUNA_DEBUG_AUDIO=false

# Existing local desktop compatibility database
GIADA_DATABASE_URL=file:./data/giada.sqlite
SEARXNG_URL=http://127.0.0.1:8080
