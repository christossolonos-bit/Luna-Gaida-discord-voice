# Backend secrets. Keep these on the server side only.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-native-audio-preview-12-2025
GEMINI_API_VERSION=v1alpha
NVIDIA_API_KEY=
NVIDIA_NIM_URL=https://integrate.api.nvidia.com/v1/chat/completions
NVIDIA_IMAGE_MODEL=moonshotai/kimi-k2.6
GIADA_SERVER_HOST=127.0.0.1
GIADA_SERVER_PORT=8787
GIADA_DATABASE_URL=file:./data/giada.sqlite
# Disabled by default. Enables writeMemory and retrieveMemory on web/app and Discord.
GIADA_MEMORY_TOOLS_ENABLED=false

# Optional Discord addon.
DISCORD_BOT_TOKEN=
DISCORD_BEARER_TOKEN=
DISCORD_APPLICATION_ID=
DISCORD_PUBLIC_KEY=
DISCORD_GUILD_ID=
DISCORD_REGISTER_GLOBAL_COMMANDS=false

# Discord voice music playback.
YTDLP_BINARY=yt-dlp
YTDLP_PLAYER_CLIENTS=default
# Native/non-Docker path. Docker Compose overrides this with /run/secrets/youtube-cookies.txt.
YTDLP_COOKIES_PATH=
# Usually unsuitable in Docker unless the browser profile is also mounted.
YTDLP_COOKIES_FROM_BROWSER=
FFMPEG_BINARY=ffmpeg
DISCORD_MUSIC_VOLUME=0.35
DISCORD_MUSIC_DUCK_VOLUME=0.12

# Private web search tool. In Docker Compose this resolves to the internal SearXNG service.
SEARXNG_URL=http://searxng:8080

# Local policy defaults.
GIADA_DEFAULT_LANGUAGE=it-IT
GIADA_ALLOWED_ORIGINS=tauri://localhost,http://localhost:1420
