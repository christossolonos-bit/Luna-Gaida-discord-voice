# Core service
GIADA_SERVER_HOST=127.0.0.1
GIADA_SERVER_PORT=8787
GIADA_PUBLIC_URL=http://127.0.0.1:8787
GIADA_POSTGRES_URL=postgresql://giada:change-me@127.0.0.1:5432/giada
# Generate with: openssl rand -base64 32
GIADA_MASTER_KEY=
GIADA_OWNER_DISCORD_USER_ID=

# Discord bot and dashboard OAuth application
DISCORD_BOT_TOKEN=
DISCORD_APPLICATION_ID=
DISCORD_CLIENT_SECRET=
DISCORD_PUBLIC_KEY=

# Stripe test/live credentials
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Provider models and endpoints.
# Luna brain: local Ollama (OpenAI-compatible chat API).
# Legacy GROQ_* env vars still work as fallbacks if OLLAMA_* is unset.
# GEMINI_* is unused when GIADA_VOICE_PROVIDER=local.
GEMINI_MODEL=gemini-live-2.5-flash-native-audio
OLLAMA_API_URL=http://127.0.0.1:11434/v1/chat/completions
OLLAMA_MODEL=qwen3.5:4b
OLLAMA_TIMEOUT_MS=180000
OLLAMA_REASONING_EFFORT=none
NVIDIA_IMAGE_MODEL=moonshotai/kimi-k2.6

# Local Discord voice (faster-whisper STT + Fish Audio or XTTS + Ollama). Set GIADA_VOICE_PROVIDER=local to enable.
GIADA_VOICE_PROVIDER=local
LOCAL_VOICE_PYTHON=python
LOCAL_VOICE_SCRIPT=./scripts/local_voice_service.py
WHISPER_MODEL=base
WHISPER_LANGUAGE=en
WHISPER_NO_SPEECH_THRESHOLD=0.35
FFMPEG_BINARY=ffmpeg

# TTS: fish = Fish Audio API (1 request per Luna message), xtts = local Coqui XTTS
LUNA_TTS_PROVIDER=fish
FISH_AUDIO_API_KEY=
FISH_AUDIO_REFERENCE_ID=
FISH_AUDIO_MODEL=s2.1-pro-free
# Dynamic delivery: prosody shifts per line from emotion tags; optional alternate Fish voice IDs
FISH_AUDIO_DYNAMIC_VOICE=true
# FISH_AUDIO_REFERENCE_ID_SHOUT=
# FISH_AUDIO_REFERENCE_ID_WHISPER=
# FISH_AUDIO_REFERENCE_ID_SAD=
# Excited Gamer — used when Luna is hyped or playful
FISH_AUDIO_REFERENCE_ID_EXCITED=58be4f99b95a45378a0a90179e4fe488

# Video vision — Ollama qwen3.5:4b describes snapshot frames from shared videos
LUNA_VIDEO_VISION=true
LUNA_VIDEO_VISION_PROVIDER=ollama
LUNA_VIDEO_VISION_FRAMES=3
# After this many hours away, Luna may feel the gap (mood varies by bond)
LUNA_ABSENCE_MISS_HOURS=3
# Full tuzi anhei: D:/tuzi_anhei/tuzi anhei.luna.model3.json
# Lite tuzi mian: D:/live2d model viewer/tuzi_mian__2_/tuzi mian.model3.json
LUNA_LIVE2D_MODEL=
# OBS: one Luna window — use dock monitor button to move between displays
LUNA_OVERLAY_SCOPE=primary
# Demitra — used when Luna's bond with someone is hostile
FISH_AUDIO_REFERENCE_ID_HOSTILE=7b80df7aef1144b69644839e4e1426d9
XTTS_SPEAKER_WAV=./voices/Serafina - Sensual Temptress_pvc_sp92_s31_sb81_v3.mp3
XTTS_LANGUAGE=en

# Luna voice behavior
LUNA_VOICE_INPUT_MODE=ptt
LUNA_WAKE_REQUIRED=false
LUNA_WAKE_PHRASES=hey luna,hello luna
LUNA_SPEECH_END_SILENCE_MS=5000
LUNA_ECHO_MUTE_MS=1200
LUNA_USER_VOICE_MEMORY=true
LUNA_LIFE_MEMORY=true
LUNA_DEBUG_AUDIO=false
# Fluffy/Electron TTS playback gain (1.0 = normal, 2.5 = louder default)
LUNA_TTS_VOLUME=2.5

# Existing local desktop compatibility database
GIADA_DATABASE_URL=file:./data/giada.sqlite
SEARXNG_URL=http://127.0.0.1:8080
# Primary web search: duckduckgo (default) or searxng. DuckDuckGo needs no local server.
LUNA_SEARCH_PROVIDER=duckduckgo
