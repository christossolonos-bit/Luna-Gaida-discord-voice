{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Luna",
  "version": "0.1.0",
  "identifier": "com.luna.desktop-companion",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "Luna",
        "url": "/",
        "width": 1180,
        "height": 760,
        "minWidth": 900,
        "minHeight": 620,
        "decorations": true,
        "transparent": false,
        "backgroundThrottling": "disabled"
      },
      {
        "label": "avatar",
        "title": "Luna",
        "url": "/avatar.html",
        "width": 360,
        "height": 620,
        "alwaysOnTop": true,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "resizable": false,
        "backgroundColor": "#00000001",
        "backgroundThrottling": "disabled"
      }
    ],
    "security": {
      "csp": "default-src 'self' asset: http://asset.localhost; connect-src 'self' ws://127.0.0.1:8787 http://127.0.0.1:8787 asset: http://asset.localhost; img-src 'self' asset: http://asset.localhost data: blob:; media-src 'self' asset: http://asset.localhost data: blob:; script-src 'self'; style-src 'self' 'unsafe-inline'",
      "assetProtocol": {
        "enable": true,
        "scope": ["D:/live2d model viewer/**"]
      },
      "capabilities": ["main", "avatar"]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": {
      "../public/assets": "assets"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
